{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "argocd": {
    "managerFilePatterns": [
      "/^k8s/.+\\.ya?ml/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/.*ya?ml$/"
      ],
      "matchStrings": [
        "docker_repository:\\s*[\"']?(?<depName>[^\\s\"']+?)[\"']?\\s*\\n\\s*docker_tag:\\s*[\"']?(?<currentValue>[^\\s@\"']+?)(?:@(?<currentDigest>sha256:[a-f0-9]+))?[\"']?\\s*$"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": [
        "/^k8s\\/(?!.*\\/(?:deployment|daemonset)\\.ya?ml$).+\\.ya?ml$/"
      ],
      "matchStrings": [
        "image:\\s*[\"']?(?<depName>[^\\s:\"'@]+?):(?<currentValue>[^\\s@\"']+?)(?:@(?<currentDigest>sha256:[a-f0-9]+))?[\"']?\\s*$",
        "repository:\\s*[\"']?(?<depName>[^\\s\"']+?)[\"']?\\s*\\n\\s*tag:\\s*[\"']?(?<currentValue>[^\\s@\"']+?)(?:@(?<currentDigest>sha256:[a-f0-9]+))?[\"']?\\s*$"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "k3s-io/k3s",
      "managerFilePatterns": [
        "/^group_vars/k3s\\.yml$/"
      ],
      "matchStrings": [
        "k3s_release_version: (?<currentValue>.*?)\\n"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "badaix/snapcast",
      "managerFilePatterns": [
        "/^roles/snapcast/defaults/main\\.yml$/"
      ],
      "matchStrings": [
        "snapcast_version: (?<currentValue>.*?)\\n"
      ]
    }
  ],
  "extends": [
    "github>LamaCorp/infrastructure:renovate-presets.json"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/^k8s/.+\\.ya?ml$/"
    ]
  },
  "kustomize": {
    "managerFilePatterns": [
      "/^k8s/.+/kustomization\\.ya?ml$/"
    ]
  }
}
