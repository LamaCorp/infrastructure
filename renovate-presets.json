{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "dependencyDashboardLabels": [
    "dependencies"
  ],
  "description": "Default preset for use with Lama Corp. repos",
  "extends": [
    ":assignee(rissson)",
    ":disableRateLimiting",
    ":enablePreCommit",
    ":enableVulnerabilityAlerts",
    ":gitSignOff",
    ":label(dependencies)",
    ":preserveSemverRanges",
    ":semanticCommits",
    "config:best-practices",
    "mergeConfidence:all-badges"
  ],
  "git-submodules": {
    "enabled": true
  },
  "internalChecksFilter": "strict",
  "nix": {
    "enabled": true
  }
}
